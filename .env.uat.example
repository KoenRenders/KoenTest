# UAT — kopieer naar .env.uat en vul in
DB_USER=postgres
DB_PASSWORD=change-me

# JWT — genereer met: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# Debug — zet op true om magic links in de logs te tonen
DEBUG=false

# Gmail
GMAIL_USER=koen.renders@gmail.com
GMAIL_APP_PASSWORD=
GMAIL_FROM=raakmillegem@gmail.com

# Mollie — gebruik test-sleutel voor UAT
MOLLIE_API_KEY=your_mollie_test_key_here

# Lidmaatschap-hernieuwing — bankgegevens voor overschrijving (vul in per .env)
MEMBERSHIP_IBAN=
MEMBERSHIP_BENEFICIARY=

# URLs — vul je eigen UAT-domein in
FRONTEND_URL=https://uat.your-domain.example
PUBLIC_URL=https://uat.your-domain.example

# Lidmaatschapsprijzen en datumgrenzen (optioneel — onderstaande waarden zijn de standaard)
# MEMBERSHIP_PRICE_FULL=35.00
# MEMBERSHIP_PRICE_HALF=17.50
# MEMBERSHIP_HALF_PRICE_START_MD=04-16
# MEMBERSHIP_HALF_PRICE_END_MD=09-16
# MEMBERSHIP_NEXT_YEAR_FROM_MD=09-17

# Logniveau: DEBUG | INFO | WARNING | ERROR (rijkdom van de app-logs)
# INFO is goed voor dev/HDEV/UAT; WARNING voor PROD
# LOG_LEVEL=INFO
#
# SQL-echo: logt ALLE queries met bind-parameters (mogelijk persoonsgegevens).
# Staat LOS van LOG_LEVEL en standaard uit. Geblokkeerd op uat/prod.
# SQL_ECHO=false

# Inschrijvingslimieten (optioneel — onderstaande waarden zijn de standaard)
# MAX_ITEM_QUANTITY=50                 # max. aantal per inschrijvingsitem
# MAX_REGISTRATIONS_PER_EMAIL=3        # max. inschrijvingen per e-mail per activiteit
