# Connectie-info voor de /release-skill (SSH-deploy + loganalyse).
# ─────────────────────────────────────────────────────────────────────────────
# Dit bestand hoort NIET in de repo (public). Kopieer het naar `.deploy.env`
# (dat is gitignored) OF — nog veiliger — naar een map BUITEN de repo, bv.
# ~/Nextcloud/development/raak-deploy.env. `source` het daarna vóór je de CLI
# opent:   source ~/Nextcloud/development/raak-deploy.env && claude
#
# Bevat enkel host/user/paden + het PAD naar je private key — nooit de key zelf.
# De private key blijft in ~/.ssh en verhuist nergens heen.

# ── SSH-verbinding (gedeeld — één Hetzner-server) ────────────────────────────
export DEPLOY_SSH_HOST=jouw-host-of-ssh-alias
export DEPLOY_SSH_USER=jouw-ssh-user
export DEPLOY_SSH_KEY=~/.ssh/jouw_private_key      # pad; weglaatbaar bij een ~/.ssh/config-alias
# export DEPLOY_SSH_PORT=22

# ── Checkout-mappen op de server (per milieu verschillend) ───────────────────
export DEPLOY_HDEV_DIR=/pad/naar/hdev
export DEPLOY_UAT_DIR=/pad/naar/uat
export DEPLOY_PROD_DIR=/pad/naar/prod
export DEPLOY_CADDY_DIR=/pad/naar/caddy

# ── Optioneel: droog doorlopen (print de commando's i.p.v. ze uit te voeren) ──
# export DEPLOY_DRY_RUN=1
