# DEV — kopieer naar .env.dev en vul in
DB_USER=postgres
DB_PASSWORD=change-me

# JWT — genereer met: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# Gmail (optioneel voor DEV)
GMAIL_USER=koen.renders@gmail.com
GMAIL_APP_PASSWORD=
GMAIL_FROM=raakmillegem@gmail.com

# Mollie — gebruik test-sleutel
MOLLIE_API_KEY=your_mollie_test_key_here

# Chatbot 'Raakje' (#205) — LLM achter een swapbaar laagje.
# CHAT_ENABLED = hoofdschakelaar (endpoint + widget). Standaard uit; zet op true
# zodra je de bot live wil (na key + HDEV-test). Eén var dekt backend + frontend.
# CHAT_ENABLED=false
# CHAT_LLM_PROVIDER: auto (Mistral zodra MISTRAL_API_KEY staat, anders mock) | mistral | mock
# Zonder key draait de bot kosteloos in mock-modus.
# MISTRAL_API_KEY=your_mistral_key_here
#
# STT-spraakinvoer fallback via Voxtral Realtime (Mistral, EU) (#282). Hergebruikt
# dezelfde MISTRAL_API_KEY. STT_VOXTRAL_ENABLED = hoofdschakelaar, standaard uit
# (dark) → de WS-route weigert de handshake; zet op true na HDEV-smoke tegen Voxtral.
# STT_VOXTRAL_ENABLED=false
# CHAT_LLM_PROVIDER=auto
# CHAT_MODEL=mistral-small-latest
# CHAT_MAX_INPUT_CHARS=2000
# CHAT_MAX_HISTORY_MESSAGES=20
# CHAT_DAILY_CHAR_BUDGET=20000
# CHAT_MAX_TOOL_ROUNDS=4

# Overschrijvings-instructies (#157) — rekeningnummer + begunstigde voor de
# betaalmail bij betaaltype overschrijving. PAYMENT_TERM_DAYS = betaaltermijn (default 7).
PAYMENT_IBAN=
PAYMENT_BENEFICIARY=
# PAYMENT_TERM_DAYS=7

# URLs — lokaal via Caddy op poort 80
FRONTEND_URL=http://localhost
PUBLIC_URL=http://localhost

# Omgevingsindicator (#145) — optionele override van de balk-/accentkleur (hex).
# Leeg laten = standaardkleur voor deze omgeving (via compose). DEV-default: #7C3AED (paars).
# ENV_COLOR=#7C3AED

# Lidmaatschapsprijzen en datumgrenzen (optioneel — onderstaande waarden zijn de standaard)
# MEMBERSHIP_PRICE_FULL=35.00
# MEMBERSHIP_PRICE_HALF=17.50
# MEMBERSHIP_HALF_PRICE_START_MD=04-16
# MEMBERSHIP_HALF_PRICE_END_MD=09-16
# MEMBERSHIP_NEXT_YEAR_FROM_MD=09-17
# Vanaf wanneer bestaande leden al kunnen hernieuwen (geen inline comment achter de waarde!)
MEMBERSHIP_RENEWAL_START_MD=09-01

# Logniveau: DEBUG | INFO | WARNING | ERROR (rijkdom van de app-logs)
# INFO is goed voor dev/HDEV/UAT; WARNING voor PROD
# LOG_LEVEL=INFO
#
# SQL-echo: logt ALLE queries met bind-parameters (mogelijk persoonsgegevens).
# Staat LOS van LOG_LEVEL en standaard uit. Enkel voor diepe lokale diagnose;
# geblokkeerd op uat/prod.
# SQL_ECHO=false

# Inschrijvingslimieten (optioneel — onderstaande waarden zijn de standaard)
# MAX_ITEM_QUANTITY=50                 # max. aantal per inschrijvingsitem
# MAX_REGISTRATIONS_PER_EMAIL=3        # max. inschrijvingen per e-mail per activiteit
