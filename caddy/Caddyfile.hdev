# Hetzner DEV — geen SSL, bereikbaar via IP op poort 8081
:8081 {
	handle /api/* {
		reverse_proxy backend:8000
	}
	# Umami (laag 1) draait op een eigen poort (8082, root), niet via Caddy: het
	# prebuilt image past runtime-BASE_PATH niet toe → geen subpad. Zie docs/umami.md.
	handle {
		reverse_proxy frontend:3000
	}
}
