# Hetzner DEV — geen SSL, bereikbaar via IP op poort 8081
:8081 {
	# Compressie (#303): scheelt bandbreedte/laadtijd op HTML/CSS/JS.
	encode zstd gzip
	# Nul Node (React-exit #405): alles — API, statics en alle
	# server-rendered pagina's — komt uit de backend. De per-pad-blokken
	# uit de hybride omklap-periode zijn overbodig geworden en opgeruimd.
	reverse_proxy backend:8000
}
