# PROD — kopieer naar .env.prod en vul in
DB_USER=postgres
DB_PASSWORD=change-me

# JWT — genereer met: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# Debug — altijd false in productie!
DEBUG=false

# Gmail
GMAIL_USER=koen.renders@gmail.com
GMAIL_APP_PASSWORD=
GMAIL_FROM=raakmillegem@gmail.com

# Mollie — gebruik live-sleutel voor PROD
MOLLIE_API_KEY=your_mollie_live_key_here

# Chatbot 'Raakje' (#205) — LLM achter een swapbaar laagje. Productie draait op
# Mistral (EU-verwerker). Zonder key valt de bot kosteloos terug op mock-modus.
# CHAT_ENABLED = hoofdschakelaar (endpoint + widget). Standaard uit; zet op true
# zodra je de bot live wil (na key + HDEV-test). Eén var dekt backend + frontend.
# CHAT_ENABLED=false
# CHAT_LLM_PROVIDER: auto (Mistral zodra MISTRAL_API_KEY staat, anders mock) | mistral | mock
# MISTRAL_API_KEY=your_mistral_key_here
#
# STT-spraakinvoer van chatbot Raakje (#282/#290). Hergebruikt dezelfde MISTRAL_API_KEY.
#
# STT_MODE — strategie (wie verwerkt de spraak, per browser):
#   browser_only  : enkel native browser-STT (Web Speech API); browsers zonder native
#                   krijgen geen mic. Géén Voxtral. (default — veilig/dark)
#   native_first  : native waar de browser het ondersteunt, anders via de provider (Voxtral).
#   provider_only : altijd via de provider (Voxtral), ook als de browser native kan (bv. EU/GDPR).
#
# STT_PROVIDER — server-side bron (enkel gebruikt bij native_first/provider_only):
#   voxtral : Voxtral Realtime (Mistral, EU). (default) Vereist MISTRAL_API_KEY + mistralai[realtime].
#   mock    : afhankelijkheidsvrije test-stub — enkel voor CI/dev, nooit in een echte deploy.
#
# Zet STT_MODE pas op native_first/provider_only na een HDEV-smoke tegen Voxtral.
# STT_MODE=browser_only
# STT_PROVIDER=voxtral
# CHAT_LLM_PROVIDER=auto
# CHAT_MODEL=mistral-small-latest
# CHAT_MAX_INPUT_CHARS=2000
# CHAT_MAX_HISTORY_MESSAGES=20
# CHAT_DAILY_CHAR_BUDGET=20000
# CHAT_MAX_TOOL_ROUNDS=4

# Overschrijvings-instructies (#157) — rekeningnummer + begunstigde voor de
# betaalmail bij betaaltype overschrijving. PAYMENT_TERM_DAYS = betaaltermijn (default 7).
PAYMENT_IBAN=
PAYMENT_BENEFICIARY=
# PAYMENT_TERM_DAYS=7

# URLs — PROD via gedeelde Caddy met HTTPS (vul je eigen domein in)
FRONTEND_URL=https://prod.your-domain.example
PUBLIC_URL=https://prod.your-domain.example

# Omgevingsindicator (#145): PROD heeft bewust GEEN indicator (geen balk/prefix).
# Laat ENV_COLOR leeg; enkel niet-PROD omgevingen tonen een gekleurde balk.
# ENV_COLOR=

# Web-analytics — Umami (#152/#176, laag 1). Zie docs/umami.md. Via subdomein door
# de gedeelde Caddy (stats.<domein>), eigen DB umami_prod (dagelijks geback-upt).
# APP_SECRET: genereer met python3 -c "import secrets; print(secrets.token_hex(32))"
UMAMI_APP_SECRET=change-me
# Optioneel: volledige DB-URL als het wachtwoord een URL-speciaal teken bevat
# (bv. # -> %23): UMAMI_DATABASE_URL=postgresql://USER:PASS%23@db:5432/umami_prod
# Frontend tracking (build-time). WEBSITE_ID leeg laten tot je in de Umami-UI een
# website hebt aangemaakt; dan invullen en de frontend herbouwen. Leeg = no-op.
# NEXT_PUBLIC_UMAMI_SRC=https://stats.your-domain.example/script.js
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# Lidmaatschapsprijzen en datumgrenzen (optioneel — onderstaande waarden zijn de standaard)
# MEMBERSHIP_PRICE_FULL=35.00
# MEMBERSHIP_PRICE_HALF=17.50
# MEMBERSHIP_HALF_PRICE_START_MD=04-16
# MEMBERSHIP_HALF_PRICE_END_MD=09-16
# MEMBERSHIP_NEXT_YEAR_FROM_MD=09-17
# Vanaf wanneer bestaande leden al kunnen hernieuwen (geen inline comment achter de waarde!)
MEMBERSHIP_RENEWAL_START_MD=09-01

# Logniveau: DEBUG | INFO | WARNING | ERROR (rijkdom van de app-logs)
# INFO is goed voor dev/HDEV/UAT; WARNING voor PROD
# LOG_LEVEL=WARNING
#
# SQL-echo: logt ALLE queries met bind-parameters (mogelijk persoonsgegevens).
# Staat LOS van LOG_LEVEL en standaard uit. Geblokkeerd op uat/prod.
# SQL_ECHO=false

# Inschrijvingslimieten (optioneel — onderstaande waarden zijn de standaard)
# MAX_ITEM_QUANTITY=50                 # max. aantal per inschrijvingsitem
# MAX_REGISTRATIONS_PER_EMAIL=3        # max. inschrijvingen per e-mail per activiteit
